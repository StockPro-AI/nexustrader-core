# ============================================================
# NexusTrader Core - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- TRADING MODE ---
# confirm = manual approval required per signal
# yolo    = fully autonomous trading
TRADING_MODE=confirm

# --- DRY RUN (set to false for live trading) ---
DRY_RUN=true

# --- HYPERLIQUID ---
HL_API_KEY=your_hyperliquid_api_key_here
HL_API_SECRET=your_hyperliquid_api_secret_here
HL_TESTNET=true

# --- RISK MANAGEMENT ---
MAX_DAILY_LOSS_PCT=2.0
MAX_OPEN_POSITIONS=5
MAX_POSITION_SIZE_USD=500
MAX_LEVERAGE=5
KILL_SWITCH=false

# --- FREQTRADE ---
FREQTRADE_API_SERVER_URL=http://freqtrade:8080
FREQTRADE_API_USER=admin
FREQTRADE_API_PASS=changeme

# --- ORCHESTRATOR ---
ORCHESTRATOR_PORT=8000
SECRET_KEY=change_this_secret_key_in_production

# --- NOTIFICATIONS ---
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- DATABASE ---
DB_PATH=/app/data/nexustrader.db

# --- FREQAI ---
FREQAI_ENABLED=true
FREQAI_MODEL=LightGBMRegressor
FREQAI_TRAIN_PERIOD_DAYS=30
FREQAI_BACKTEST_PERIOD_DAYS=7
